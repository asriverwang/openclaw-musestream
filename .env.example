# ── MuseStream Configuration ──────────────────────────────────────────────────

# Music generation provider (default: sonauto)
MUSIC_PROVIDER=sonauto

# Sonauto API key — register at https://sonauto.ai
SONAUTO_API_KEY=

# Output directory for saved generated songs (default: ~/Music/MuseStream)
# MUSESTREAM_OUTPUT_DIR=~/Music/MuseStream

# Server port (default: 5000)
# MUSESTREAM_PORT=5000

# ── Optional: Context-aware prompt generation ──────────────────────────────────
# Priority order: MiniMax M2.7 → Claude Haiku → rule-based fallback

# MiniMax M2.7 — register at https://minimaxi.chat
MINIMAX_API_KEY=

# Anthropic Claude Haiku — register at https://console.anthropic.com
ANTHROPIC_API_KEY=
